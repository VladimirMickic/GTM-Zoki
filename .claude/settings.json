{
  "permissions": {
    "deny": [
      "Read(./.env)",
      "Read(./credentials/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/secret_guard.py\""
          }
        ]
      }
    ]
  }
}
